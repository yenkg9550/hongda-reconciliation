# ===== 應用 =====
APP_ENV=development
APP_DEBUG=true
API_V1_PREFIX=/api/v1
CORS_ORIGINS=http://localhost:5173,http://localhost:4173

# ===== MongoDB Atlas =====
# Atlas 連線字串（從 Atlas 畫面複製）；本機 Docker 改成 mongodb://localhost:27017
MONGODB_URI=mongodb+srv://USER:PASSWORD@CLUSTER.mongodb.net/?retryWrites=true&w=majority
MONGODB_DB=reconciliation

# ===== Worker =====
WORKER_INTERVAL_SECONDS=5
WORKER_MAX_RETRY=3

# ===== 開發/測試 =====
# true 時，遇到 Mongo 連線錯誤會 fallback 到 mongomock-motor（in-memory，僅供 demo）
USE_INMEMORY_FALLBACK=false
